<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.credithistory.client.ClientController"
      stylesheets="@style.css">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Верхняя панель -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="userInfoLabel" text="Сотрудник: " style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Обновить" onAction="#handleRefresh" styleClass="button-gray"/>
        <Button text="Выход" onAction="#handleLogout" styleClass="button-red"/>
    </HBox>

    <Separator/>

    <!-- Поиск -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-panel">
        <Label text="Поиск:"/>
        <TextField fx:id="searchField" promptText="Введите ФИО клиента" HBox.hgrow="ALWAYS"/>
        <Button text="Найти" onAction="#handleSearch" styleClass="button-green"/>
        <Button text="Сбросить" onAction="#handleResetSearch" styleClass="button-gray"/>
    </HBox>

    <!-- Таблица клиентов -->
    <Label text="Клиенты банка:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="fullNameColumn" text="ФИО" prefWidth="200"/>
            <TableColumn fx:id="passportColumn" text="Паспорт" prefWidth="120"/>
            <TableColumn fx:id="phoneColumn" text="Телефон" prefWidth="120"/>
            <TableColumn fx:id="ratingColumn" text="Рейтинг" prefWidth="80"/>
        </columns>
    </TableView>

    <!-- Кнопки управления клиентами -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Добавить клиента" onAction="#handleAddClient" styleClass="button-green"/>
        <Button text="Редактировать" onAction="#handleEditClient" styleClass="button-yellow"/>
        <Button text="Удалить" onAction="#handleDeleteClient" styleClass="button-red"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Кредитная история" onAction="#handleShowCreditHistory" styleClass="button-gray"/>
        <Button text="Оформить кредит" onAction="#handleAddCredit" styleClass="button-green"/>
    </HBox>

    <Separator/>

    <!-- Таблица кредитов -->
    <Label fx:id="selectedClientLabel" text="Кредиты клиента: не выбран"
           style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TableView fx:id="creditsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="creditIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="creditAmountColumn" text="Сумма" prefWidth="100"/>
            <TableColumn fx:id="creditTermColumn" text="Срок (мес.)" prefWidth="80"/>
            <TableColumn fx:id="creditRateColumn" text="Ставка (%)" prefWidth="80"/>
            <TableColumn fx:id="creditDateColumn" text="Дата выдачи" prefWidth="100"/>
            <TableColumn fx:id="creditStatusColumn" text="Статус" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- Кнопки управления кредитами -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="График платежей" onAction="#handleShowPayments" styleClass="button-green"/>
        <Button text="Закрыть кредит" onAction="#handleCloseCredit" styleClass="button-yellow"/>
    </HBox>

    <!-- Статусная строка -->
    <Label fx:id="statusLabel" text="Готово" styleClass="status-label"/>
</VBox>