<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.credithistory.client.ClientDialogController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label fx:id="titleLabel" text="Добавить клиента" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="80"/>
            <ColumnConstraints prefWidth="250"/>
        </columnConstraints>

        <Label text="ФИО:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fullNameField" promptText="Иванов Иван Иванович" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Паспорт:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="passportField" promptText="AB1234567" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Телефон:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" promptText="+375291234567" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" promptText="client@mail.com" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Адрес:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="addressField" promptText="г. Минск, ул. Ленина, д. 1" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Сохранить" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Отмена" onAction="#handleCancel"/>
    </HBox>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: red;"/>
</VBox>